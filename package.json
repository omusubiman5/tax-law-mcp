{
  "name": "tax-law-mcp",
  "version": "0.2.0",
  "description": "MCP server for Japanese tax law — e-Gov API & NTA 通達 (administrative circulars)",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "tax-law-mcp": "dist/index.js"
  },
  "files": [
    "dist/**/*"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kentaroajisaka/tax-law-mcp"
  },
  "keywords": [
    "mcp",
    "tax",
    "japan",
    "law",
    "e-gov",
    "claude"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  }
}
